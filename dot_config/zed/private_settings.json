// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "cli_default_open_behavior": "existing_window",
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "elixir": true
  },
  "icon_theme": "Catppuccin Mocha",
  "project_panel": {
    "dock": "left"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "max_scroll_history_lines": 10000
  },
  "multi_cursor_modifier": "alt",
  "minimap": {
    "show": "never"
  },
  "buffer_font_family": "Fira Mono",
  "file_types": {
    "markdown": ["*.mdx"],
    "scss": ["*.css"],
    "javascript": ["*.jsx"],
    "html": ["*.liquid", "*.njk"]
  },
  "linked_edits": true,
  "tab_size": 2,
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Mirage"
  },
  // Elixir stuff
  "languages": {
    "Elixir": {
      "language_servers": [
        "dexter",
        "!expert",
        "!next-ls",
        "!lexical",
        "!elixir-ls"
      ]
    }
  },
  "lsp": {
    "dexter": {
      "binary": {
        "path": "~/.asdf/shims/dexter",
        "arguments": ["lsp"]
      },
      "initialization_options": {
        "followDelegates": true
      }
    }
  }
}
