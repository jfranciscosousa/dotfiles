{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(grep *)"
    ],
    "defaultMode": "auto"
  },
{{- if not (hasPrefix "Remote" .chezmoi.hostname) }}
  "env": {
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
{{- end }}
  "model": "{{ if hasPrefix "Remote" .chezmoi.hostname }}opus[1m]{{ else }}claude-sonnet-4-6{{ end }}",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "effortLevel": "xhigh",
  "tui": "fullscreen",
  "preferredNotifChannel": "terminal_bell",
  "skipAutoPermissionPrompt": true
}
