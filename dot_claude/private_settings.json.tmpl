{
  "permissions": {
    "allow": [
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(grep *)"
    ],
    "defaultMode": "auto"
  },
  "model": "{{ if hasPrefix "Remote" .chezmoi.hostname }}opus[1m]{{ else }}claude-sonnet-4-6{{ end }}",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "rtk hook claude"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "effortLevel": "high",
  "skipAutoPermissionPrompt": true
}
