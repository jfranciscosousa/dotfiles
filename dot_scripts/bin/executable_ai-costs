#!/usr/bin/env ruby
# frozen_string_literal: true

require "bundler/inline"

gemfile(false) do
  source "https://rubygems.org"
  gem "chronic"
  gem "pastel"
  gem "tty-table"
end

require "json"
require "date"
require "open-uri"
require "open3"
require "set"
require "tmpdir"

# Formats a token count as a human-readable string (e.g. 1_500_000 → "1.5M").
def format_tokens(count)
  if count >= 1_000_000_000
    format("%.1fB", count / 1_000_000_000.0)
  elsif count >= 1_000_000
    format("%.1fM", count / 1_000_000.0)
  elsif count >= 1_000
    format("%.1fK", count / 1_000.0)
  else
    count.to_s
  end
end

# Truncates a conversation title to ~6 words so it fits inline next to the cost.
TITLE_WORD_LIMIT = 6
def truncate_title(title)
  return "(untitled)" if title.nil? || title.strip.empty?

  cleaned = title.to_s.gsub(/\s+/, " ").strip
  words   = cleaned.split(" ")
  return cleaned if words.length <= TITLE_WORD_LIMIT

  "#{words.first(TITLE_WORD_LIMIT).join(' ')}…"
end

# Strips provider-specific prefixes from a model ID so it matches the pricing table.
# e.g. "eu.anthropic.claude-opus-4-7" → "claude-opus-4-7".
def normalize_model(model)
  model.to_s
       .sub(/\A(?:us|eu|apac)\./, "")
       .sub(/\Aanthropic[.\/]/, "")
       .sub(%r{\A(?:openai|azure|azure_ai)/}, "")
end

# Fetches model pricing ($/1M tokens) from LiteLLM's public JSON, cached for 24h in the
# system temp dir. Normalizes model keys by stripping provider prefixes and version suffixes.
LITELLM_URL       = "https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json"
PRICING_CACHE     = Pathname.new(Dir.tmpdir).join("ai-costs-pricing.json")
PRICING_CACHE_TTL = 86_400

def fetch_pricing
  raw =
    if PRICING_CACHE.exist? && (Time.now - PRICING_CACHE.mtime) < PRICING_CACHE_TTL
      JSON.parse(PRICING_CACHE.read)
    else
      body = URI.open(LITELLM_URL, open_timeout: 5, read_timeout: 10).read
      PRICING_CACHE.write(body)
      JSON.parse(body)
    end

  pricing = {}
  raw.each do |key, data|
    model = normalize_model(key)
            .sub(/-v\d+:\d+\z/, "")
            .sub(/-v\d+\z/, "")
            .sub(/@.+\z/, "")
    next unless model.start_with?("claude-", "gpt-")

    input       = ((data["input_cost_per_token"]            || 0) * 1_000_000).round(4)
    output      = ((data["output_cost_per_token"]           || 0) * 1_000_000).round(4)
    cache_write = ((data["cache_creation_input_token_cost"] || 0) * 1_000_000).round(4)
    cache_read  = ((data["cache_read_input_token_cost"]     || 0) * 1_000_000).round(4)
    next if input.zero? && output.zero?

    pricing[model] = { input: input, output: output, cache_write: cache_write, cache_read: cache_read }
  end
  abort "No supported model pricing found in response" if pricing.empty?
  pricing
end

PRICING = fetch_pricing

# Computes the dollar cost for a single assistant message given its model and usage stats.
# Falls back to prefix matching (e.g. "claude-opus-4-7" → "claude-opus-4") when the exact
# model ID isn't in the pricing table.
def cost_for(model, input, output, cache_write, cache_read)
  rates = PRICING[model]

  unless rates
    parts = model.split("-")
    (parts.length - 1).downto(2) do |len|
      prefix = parts.first(len).join("-")
      found  = PRICING.find { |pricing_key, _| pricing_key.start_with?(prefix) }
      rates  = found.last and break if found
    end
  end

  return 0.0 unless rates

  ((input * rates[:input]) +
   (output * rates[:output]) +
   (cache_write * rates[:cache_write]) +
   (cache_read * rates[:cache_read])) / 1_000_000.0
end

# Shortens an absolute path by collapsing the user's home dir to "~".
def shorten_path(path)
  home = Dir.home
  path.start_with?(home) ? path.sub(home, "~") : path
end

# ───────────────────────────────────────────────────────────────────────────────────────
# Worktree → main repo resolution
#
# Sessions are logged against the cwd they ran in. That cwd is often a *linked worktree*
# (e.g. ~/.worktrees/fs/some-branch) rather than the actual repo. We want costs aggregated
# under the main repo so `tiger` shows one total instead of one row per branch. There are
# three flavours of cwd to handle:
#
#   (A) cwd still exists and is a git repo (main or linked worktree)
#       → `git --git-common-dir` returns the main repo's .git, parent is the answer.
#
#   (B) cwd is gone (`rm -rf`) but the main repo's bookkeeping survives
#       → While unlinked, each linked worktree leaves <main>/.git/worktrees/<name>/gitdir
#         containing the absolute path to <wt>/.git. `git worktree prune` removes those.
#         We walk every known main repo's .git/worktrees/*/gitdir and build a reverse map
#         dead_wt_path → main_repo. Works for any worktree that was just `rm`'d.
#
#   (C) cwd is gone *and* its metadata was pruned
#       → No git state left. Only signal we still have is `gitBranch` in Claude's jsonl
#         records. We scan each known main repo for that branch (current refs + reflog
#         of deleted refs). If exactly one repo has ever seen that branch, that's the
#         parent. Multi-match or no match is unrecoverable → keep the raw cwd.
#
# Known main repos for steps B and C come from two sources: (1) git resolution of every
# *living* cwd we ingested, and (2) the OpenCode `project` table, which retains historical
# worktree paths even after disk cleanup.
# ───────────────────────────────────────────────────────────────────────────────────────

# Common branch names that can't disambiguate a parent repo because every repo has one.
GENERIC_BRANCHES = %w[master main develop trunk HEAD].to_set

# Resolves a *living* path to its main repo root via git (handles case A above).
# Returns the path unchanged when the dir is gone or isn't a git repo.
REPO_ROOT_CACHE = {}
def repo_root_for(path)
  return REPO_ROOT_CACHE[path] if REPO_ROOT_CACHE.key?(path)

  resolved =
    if File.directory?(path)
      out, _err, status = Open3.capture3("git", "-C", path, "rev-parse", "--path-format=absolute", "--git-common-dir")
      if status.success?
        common_dir = out.strip
        common_dir.end_with?("/.git") ? File.dirname(common_dir) : path
      else
        path
      end
    else
      path
    end

  REPO_ROOT_CACHE[path] = resolved
end

# Returns { dead_or_live_worktree_path => main_repo_path } for any linked worktrees this
# repo still remembers. The data lives in <repo>/.git/worktrees/<name>/gitdir, which holds
# the absolute path to the worktree's .git file (drop the trailing /.git to get the dir).
# Survives `rm -rf <worktree>` but not `git worktree prune`. Powers case B.
def worktree_links(repo)
  links = {}
  Dir.glob(File.join(repo, ".git/worktrees/*/gitdir")).each do |gitdir_file|
    gitdir = File.read(gitdir_file).strip
    next if gitdir.empty?

    worktree_path = gitdir.sub(/\/\.git\z/, "")
    links[worktree_path] = repo
  end
  links
rescue StandardError
  {}
end

# Returns the set of branches a repo has ever known about: currently-checked-out refs
# (`for-each-ref refs/heads/`) plus anything still in the reflog (`reflog --all`, which
# keeps entries for deleted branches until git gc expires them). Used as the last-resort
# signal in case C — matching a Claude session's `gitBranch` against this set lets us
# guess the parent repo for a fully-pruned worktree, as long as the branch name is
# unique across repos.
BRANCHES_CACHE = {}
def branches_for(repo)
  return BRANCHES_CACHE[repo] if BRANCHES_CACHE.key?(repo)

  branches = Set.new

  current, _err, status = Open3.capture3("git", "-C", repo, "for-each-ref", "--format=%(refname:short)", "refs/heads/")
  current.each_line { |l| branches << l.strip } if status.success?

  # %gD expands to "refs/heads/<branch>@{N}" — pull the branch name back out.
  reflog, _err, status = Open3.capture3("git", "-C", repo, "reflog", "--all", "--pretty=%gD")
  reflog.scan(%r{refs/heads/(\S+?)@\{}) { |(b)| branches << b } if status.success?

  BRANCHES_CACHE[repo] = branches
rescue StandardError
  BRANCHES_CACHE[repo] = Set.new
end

# Parses a natural-language date string ("2 weeks ago", "last monday") into a Date using Chronic.
def parse_since(arg)
  parsed = Chronic.parse(arg, context: :past)
  abort "Couldn't parse '#{arg}' as a date.\n\nExamples: '2 weeks ago', 'last monday', 'april 1st', 'yesterday'" unless parsed
  parsed.to_date
end

since = parse_since(ARGV[0] || "30 days ago")
since_time_ms = Time.parse(since.to_s).to_i * 1000

# Empty token/cost bucket.
def new_bucket
  { input: 0, output: 0, cache_write: 0, cache_read: 0, cost: 0.0 }
end

# Creates an empty session record. One per Claude/OpenCode conversation.
def new_session(source, session_id)
  {
    source:        source,
    session_id:    session_id,
    cwd:           nil,
    date:          nil,   # first observed date
    title:         nil,   # filled from ai-title (Claude) or session.title (OpenCode)
    branch_counts: Hash.new(0),
    model_costs:   Hash.new(0.0),  # model => cost (used to pick the dominant model for display)
    bucket:        new_bucket
  }
end

# ───────────────────────────────────────────────────────────────────────────────────────
# Phase 1: ingest every assistant message into a per-session record. We aggregate at
# session granularity (one row per conversation) rather than per-date so the report can
# show each conversation's title alongside its cost.
# ───────────────────────────────────────────────────────────────────────────────────────

sessions       = {}  # [source, session_id] => session record
total_files    = 0
total_messages = Hash.new(0)
extra_repos    = Set.new  # additional main repos contributed by other data sources

# --- Claude Code (~/.claude/projects/**/*.jsonl) ---------------------------------------
# Each jsonl file is one conversation; sessionId is in the records and matches the filename.

projects_dir = Pathname.new(File.expand_path("~/.claude/projects"))
if projects_dir.directory?
  projects_dir.each_child do |project_dir|
    next unless project_dir.directory?

    project_dir.glob("**/*.jsonl").each do |jsonl|
      total_files += 1

      File.foreach(jsonl) do |line|
        record = begin
          JSON.parse(line)
        rescue StandardError
          next
        end

        session_id = record["sessionId"] || jsonl.basename(".jsonl").to_s
        session    = sessions[[:claude, session_id]] ||= new_session(:claude, session_id)

        # ai-title records carry the conversation title (may appear multiple times; the last
        # one wins because the model can re-title mid-conversation).
        if record["type"] == "ai-title" && record["aiTitle"]
          session[:title] = record["aiTitle"]
          next
        end

        next unless record["type"] == "assistant"

        msg = record["message"] || next
        model = msg["model"]
        usage = msg["usage"]
        next unless model && usage
        next if model == "<synthetic>"

        timestamp = record["timestamp"] || next
        date = begin
          Date.parse(timestamp)
        rescue StandardError
          next
        end
        next if date < since

        input       = usage["input_tokens"] || 0
        output      = usage["output_tokens"] || 0
        cache_write = usage["cache_creation_input_tokens"] || 0
        cache_read  = usage["cache_read_input_tokens"] || 0
        cost        = cost_for(model, input, output, cache_write, cache_read)

        session[:cwd]                ||= record["cwd"] || project_dir.basename.to_s
        session[:date]                 = date if session[:date].nil? || date < session[:date]
        session[:branch_counts][record["gitBranch"]] += 1 if record["gitBranch"] && !record["gitBranch"].empty?
        session[:model_costs][model]  += cost

        b = session[:bucket]
        b[:input]       += input
        b[:output]      += output
        b[:cache_write] += cache_write
        b[:cache_read]  += cache_read
        b[:cost]        += cost

        total_messages[:claude] += 1
      end
    end
  end
end

# --- OpenCode (~/.local/share/opencode/opencode.db) ------------------------------------
# Messages are joined to sessions by session_id; session.title gives us the conversation
# title directly.

opencode_db = Pathname.new(File.expand_path("~/.local/share/opencode/opencode.db"))
if opencode_db.file?
  query = <<~SQL
    SELECT
      message.session_id                                 AS session_id,
      json_extract(message.data, '$.modelID')            AS model,
      json_extract(message.data, '$.tokens.input')       AS input,
      json_extract(message.data, '$.tokens.output')      AS output,
      json_extract(message.data, '$.tokens.cache.write') AS cache_write,
      json_extract(message.data, '$.tokens.cache.read')  AS cache_read,
      json_extract(message.data, '$.time.created')       AS created_ms,
      json_extract(message.data, '$.path.cwd')           AS cwd,
      session.title                                      AS title
    FROM message
    LEFT JOIN session ON session.id = message.session_id
    WHERE json_extract(message.data, '$.role') = 'assistant'
      AND json_extract(message.data, '$.time.created') >= #{since_time_ms}
      AND json_extract(message.data, '$.tokens.input') IS NOT NULL
  SQL

  stdout, _stderr, status = Open3.capture3("sqlite3", "-json", opencode_db.to_s, query)
  if status.success? && !stdout.strip.empty?
    rows = begin
      JSON.parse(stdout)
    rescue StandardError
      []
    end

    rows.each do |row|
      model = normalize_model(row["model"].to_s)
      next if model.empty?

      input       = row["input"] || 0
      output      = row["output"] || 0
      cache_write = row["cache_write"] || 0
      cache_read  = row["cache_read"] || 0
      cwd         = row["cwd"] || "unknown"
      created_ms  = row["created_ms"] || 0
      session_id  = row["session_id"]
      next unless session_id

      date = Time.at(created_ms / 1000.0).to_date
      next if date < since

      cost = cost_for(model, input, output, cache_write, cache_read)

      session = sessions[[:opencode, session_id]] ||= new_session(:opencode, session_id)
      session[:cwd]               ||= cwd
      session[:date]                = date if session[:date].nil? || date < session[:date]
      session[:title]             ||= row["title"]
      session[:model_costs][model] += cost

      b = session[:bucket]
      b[:input]       += input
      b[:output]      += output
      b[:cache_write] += cache_write
      b[:cache_read]  += cache_read
      b[:cost]        += cost

      total_messages[:opencode] += 1
    end
  end

  # OpenCode's `project` table retains historical worktree paths even after a project is
  # deleted from disk. These act as extra "known main repos" so we can match cases B/C
  # against repos that no living cwd in this run happens to point at.
  projects_out, _err, projects_status = Open3.capture3("sqlite3", opencode_db.to_s, "SELECT DISTINCT worktree FROM project")
  if projects_status.success?
    projects_out.each_line do |line|
      path = line.strip
      extra_repos << path unless path.empty?
    end
  end
end

p = Pastel.new

# Drop sessions that exist only because of out-of-window metadata records (e.g. a Claude
# `ai-title` from an older conversation whose assistant messages all fall before `since`).
# Anything with no recorded assistant cost contributes nothing to the report.
sessions.reject! { |_, session| session[:model_costs].empty? }

if sessions.empty?
  puts p.yellow("No Claude Code or OpenCode sessions found since #{since}.")
  exit
end

# ───────────────────────────────────────────────────────────────────────────────────────
# Phase 2: resolve each session's cwd to its parent-repo label (cases A/B/C above).
# ───────────────────────────────────────────────────────────────────────────────────────

all_cwds    = sessions.values.map { |s| s[:cwd] }.compact.uniq
known_repos = Set.new(extra_repos)
all_cwds.each do |cwd|
  next unless File.directory?(cwd)
  known_repos << repo_root_for(cwd)
end

# Reverse worktree map across every known main repo (case B). Built once.
worktree_map = {}
known_repos.each { |repo| worktree_map.merge!(worktree_links(repo)) }

# Resolve each cwd through the case-A / case-B path first; case-C branch matching
# happens below per-session because it needs the per-session branch counts.
cwd_label = {}
all_cwds.each do |cwd|
  resolved =
    if File.directory?(cwd)
      repo_root_for(cwd)
    elsif worktree_map[cwd]
      worktree_map[cwd]
    end

  cwd_label[cwd] = resolved && shorten_path(resolved)
end

# Case C: for cwds that still don't have a label, try branch-name disambiguation against
# the known repos. We pick the most-frequently-seen branch from each session that shares
# this cwd; if a single known repo has that branch in its refs or reflog, that's the parent.
sessions.each_value do |session|
  next if cwd_label[session[:cwd]]
  next if session[:branch_counts].empty?

  branch = session[:branch_counts].max_by { |_, count| count }&.first
  next if branch.nil? || GENERIC_BRANCHES.include?(branch)

  matches = known_repos.select { |repo| branches_for(repo).include?(branch) }
  next unless matches.size == 1

  cwd_label[session[:cwd]] = shorten_path(matches.first)
end

# Final fallback: anything still unresolved keeps its raw cwd.
all_cwds.each { |cwd| cwd_label[cwd] ||= shorten_path(cwd) }

# ───────────────────────────────────────────────────────────────────────────────────────
# Phase 3: group sessions by (source, project) and render.
# ───────────────────────────────────────────────────────────────────────────────────────

# grouped[source][project_label] => Array<session>
grouped = Hash.new { |h, source| h[source] = Hash.new { |h2, label| h2[label] = [] } }
sessions.each_value do |session|
  label = cwd_label[session[:cwd]] || shorten_path(session[:cwd] || "unknown")
  grouped[session[:source]][label] << session
end

grand_total = 0.0

# Renders one source section (Claude Code / OpenCode) with per-project breakdowns.
# Within each project, sessions are sorted by cost descending so the expensive ones surface.
render_section = lambda do |source, title|
  source_grouped = grouped[source]
  return 0.0 if source_grouped.empty?

  source_total = 0.0
  puts
  puts p.bold.cyan(title) + p.dim("  ·  since #{since}")
  puts p.dim("─" * 80)

  source_grouped.sort_by { |proj, _| proj }.each do |project_name, project_sessions|
    proj_cost = project_sessions.sum { |s| s[:bucket][:cost] }
    source_total += proj_cost

    puts
    puts "  #{p.bold(project_name.ljust(44))}#{p.yellow(format('$%.4f', proj_cost))}"

    project_sessions.sort_by { |s| -s[:bucket][:cost] }.each do |session|
      bucket       = session[:bucket]
      dominant_model = session[:model_costs].max_by { |_, c| c }&.first || "?"
      short_model    = dominant_model.sub("claude-", "").sub(/-\d{8}\z/, "")
      token_in       = format_tokens(bucket[:input] + bucket[:cache_write] + bucket[:cache_read])
      token_out      = format_tokens(bucket[:output])
      title_str      = truncate_title(session[:title])

      puts "    #{p.dim(session[:date].to_s)}  " \
           "#{p.cyan(format('%-12s', short_model))}" \
           "#{p.green(format('%9s', format('$%.4f', bucket[:cost])))}  " \
           "#{p.bold(format('%-46s', title_str))} " \
           "#{p.dim("(#{token_in} in / #{token_out} out)")}"
    end
  end

  source_total
end

grand_total += render_section.call(:claude,   "Claude Code")
grand_total += render_section.call(:opencode, "OpenCode")

# Per-model totals across both sources.
model_totals = Hash.new { |h, m| h[m] = new_bucket }
sessions.each_value do |session|
  # Split a multi-model session's tokens proportionally across its models by cost share.
  # Most sessions use one model so this just attributes everything to that model; for the
  # rare multi-model conversation (Opus + Haiku subagent) it spreads the totals roughly.
  total_cost = session[:model_costs].values.sum
  next if total_cost.zero?

  session[:model_costs].each do |model, model_cost|
    share = model_cost / total_cost
    t     = model_totals[model]
    b     = session[:bucket]
    t[:cost]        += model_cost
    t[:input]       += (b[:input]       * share).round
    t[:output]      += (b[:output]      * share).round
    t[:cache_write] += (b[:cache_write] * share).round
    t[:cache_read]  += (b[:cache_read]  * share).round
  end
end

puts
puts p.dim("─" * 80)
puts p.bold("  By model")
puts

table = TTY::Table.new(
  header: ["Model", "Cost", "Input", "Cache write", "Cache read", "Output"],
  rows: model_totals.sort_by { |_, totals| -totals[:cost] }.map do |model, totals|
    [
      model.sub("claude-", "").sub(/-\d{8}\z/, ""),
      format("$%.4f", totals[:cost]),
      format_tokens(totals[:input]),
      format_tokens(totals[:cache_write]),
      format_tokens(totals[:cache_read]),
      format_tokens(totals[:output])
    ]
  end
)
puts table.render(:unicode, padding: [0, 1], alignments: %i[left right right right right right], indent: 2)

claude_msgs   = total_messages[:claude]
opencode_msgs = total_messages[:opencode]
breakdown = []
breakdown << "#{claude_msgs} claude" if claude_msgs.positive?
breakdown << "#{opencode_msgs} opencode" if opencode_msgs.positive?

puts
puts "  #{p.bold('TOTAL  ')}#{p.bold.green(format('$%.4f', grand_total))}"
puts p.dim("  #{since} – #{Date.today}  ·  #{breakdown.join(' + ')} messages · #{sessions.size} sessions · #{total_files} claude files")
puts
