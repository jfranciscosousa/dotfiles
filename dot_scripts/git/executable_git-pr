#!/usr/bin/env ruby
# git-pr - Create a GitHub pull request with an AI-generated description.
#
# Usage: git pr [options]
#
# Options:
#   -t, --target BRANCH   Target branch (default: auto-detect main/master)
#   -h                    Show this help
#
# Looks for a PR template in .github/pull_request_template.md,
# fills it in with Claude based on the branch diff, then creates the PR via gh.
require 'optparse'
require 'shellwords'

def shell(command)
  output = `#{command} 2>&1`

  unless $?.success?
    $stderr.puts "Error running: #{command}"
    $stderr.puts output unless output.strip.empty?
    exit(-1)
  end

  output
end

def detect_default_branch
  ref = `git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null`.strip
  if ref.empty?
    `git remote set-head origin --auto 2>/dev/null`
    ref = `git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null`.strip
  end
  ref.empty? ? "main" : ref.sub("refs/remotes/origin/", "")
end

def find_pr_template
  root = `git rev-parse --show-toplevel 2>/dev/null`.strip
  return [nil, nil] if root.empty?

  candidates = [
    ".github/pull_request_template.md",
    ".github/PULL_REQUEST_TEMPLATE.md",
    "pull_request_template.md",
    "PULL_REQUEST_TEMPLATE.md",
    "docs/pull_request_template.md",
  ]

  # Check exact candidates first
  candidates.each do |rel|
    path = File.join(root, rel)
    return [File.read(path), path] if File.exist?(path)
  end

  # Check for templates directory (case-insensitive)
  dir = File.join(root, ".github/PULL_REQUEST_TEMPLATE")
  unless Dir.exist?(dir)
    dir = File.join(root, ".github/pull_request_template")
  end

  if Dir.exist?(dir)
    templates = Dir.glob("#{dir}/*.md")
    default = templates.find { |f| File.basename(f).downcase == "default.md" }
    path = default || templates.first
    return [File.read(path), path] if path
  end

  [nil, nil]
end

target = nil

OptionParser.new do |opts|
  opts.banner = "Usage: git pr [options]\n\nCreate a GitHub pull request with an AI-generated description.\n\n"

  opts.on("-t", "--target BRANCH", "Target branch (default: auto-detect)") do |v|
    target = v
  end
end.parse!

remote_url = `git remote get-url origin 2>/dev/null`.strip
unless remote_url.include?("github")
  $stderr.puts "Remote origin does not point to GitHub: #{remote_url}"
  exit(1)
end

branch = shell("git rev-parse --abbrev-ref HEAD").strip
target ||= detect_default_branch

if branch == target
  $stderr.puts "Already on #{target}, nothing to merge."
  exit(1)
end

# Make sure we have the latest remote state
shell("git fetch origin #{target}")

diff = shell("git diff origin/#{target}...HEAD")
log = shell("git log origin/#{target}..HEAD --oneline")

if diff.strip.empty?
  $stderr.puts "No changes between #{branch} and #{target}."
  exit(1)
end

template, template_path = find_pr_template

if template
  puts "Using PR template: #{template_path}"
else
  puts "No PR template found, using default format."
end

if template
  prompt = <<~PROMPT
    Fill in this pull request template based on the changes below.
    The FIRST line of your output must be the PR title (short, under 72 chars).
    The SECOND line must be blank.
    Everything after that is the filled template body. Plain text with markdown. Do not wrap in a code block.

    Template:
    #{template}

    Commits:
    #{log}

    Diff:
    #{diff}
  PROMPT
else
  prompt = <<~PROMPT
    Write a GitHub pull request description for these changes.
    The FIRST line of your output must be the PR title (short, under 72 chars).
    The SECOND line must be blank.
    Everything after that is the description body with a summary section and a short test plan. Use markdown. Do not wrap in a code block.

    Commits:
    #{log}

    Diff:
    #{diff}
  PROMPT
end

puts "Generating PR description with Claude..."

claude_output = IO.popen(["claude", "--print", "--no-session-persistence", "--tools", "", "--disable-slash-commands", "--strict-mcp-config", "-"], "r+", err: [:child, :out]) do |io|
  io.write(prompt)
  io.close_write
  io.read
end
claude_status = $?

if !claude_status.success? || claude_output.strip.empty?
  $stderr.puts "Warning: Claude failed, using commit log as description."
  title = log.lines.first&.strip&.sub(/^[a-f0-9]+\s+/, "") || branch
  description = log
else
  output = claude_output.strip
  # Strip wrapping code fences if Claude wrapped the output in one
  output = output.sub(/\A```[^\n]*\n/, "").sub(/\n```\z/, "").strip
  # First line is the title, rest is the description
  lines = output.lines
  title = lines.first&.strip || branch
  description = lines.drop(1).join.strip
end

puts "Creating PR: #{title}"

# Push branch if needed
shell("git push -u origin #{branch}")

pr_output = `gh pr create --title #{title.shellescape} --body #{description.shellescape} --base #{target} 2>&1`
unless $?.success?
  $stderr.puts "Error creating PR:"
  $stderr.puts pr_output
  exit(-1)
end
puts pr_output
