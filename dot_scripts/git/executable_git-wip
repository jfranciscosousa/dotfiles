#!/usr/bin/env ruby
# This scripts adds all changes and commits with a 'wip' message
# For safety this script refuses to run on master
require 'optparse'

def shell(command)
  output = `#{command} 2>&1`

  unless $?.success?
    $stderr.puts "Error running: #{command}"
    $stderr.puts output unless output.strip.empty?
    exit(-1)
  end

  output
end

branch = shell("git rev-parse --abbrev-ref HEAD").strip

push = false
force = false
message = "wip"
no_edit = false
ai_message = false
commit_command = "git commit"

OptionParser.new do |opts|
  opts.banner = "Usage: git work [options]"

  opts.on("-p", "--push", "Push after commit") do |_v|
    push = true
  end

  opts.on("-f", "--force", "Force push") do |_v|
    force = true
  end

  opts.on("-m M", "--message M", String, "Commit message") do |v|
    message = v
  end

  opts.on("--no-verify", "Bypass pre-commit and commig-msg hooks") do |_v|
    commit_command.concat(" --no-verify")
  end

  opts.on("--no-edit", "do not edit the commit message before comitting") do |_v|
    no_edit = true
    commit_command.concat(" --no-edit")
  end

  opts.on("--amend", "amend the tip of the current branch") do |_v|
    commit_command.concat(" --amend")
  end

  opts.on("--ai", "Use Claude to auto-generate commit message from staged changes") do |_v|
    ai_message = true
  end
end.parse!

if (branch == 'master' || branch == 'main') && push && !force
  puts "Cannot use push flag on #{branch}. Please run with the --force flag if you are 100% sure of what you are doing."
  exit(-1)
end

puts shell("git add --all")

def wrap(text, width = 72)
  text.gsub(/(.{1,#{width}})(\s+|\z)/, "\\1\n").rstrip
end

if ai_message
  diff_full = `git diff --cached`

  prompt = <<~PROMPT
    Summarize this diff as: one subject line, then a blank line, then the commit description. Use bullet points for different subjects.
    #{diff_full}
  PROMPT

  claude_output = IO.popen(["claude", "--print", "--no-session-persistence", "--tools", "", "--disable-slash-commands", "--strict-mcp-config", "-"], "r+", err: [:child, :out]) do |io|
    io.write(prompt)
    io.close_write
    io.read
  end
  claude_status = $?

  if !claude_status.success?
    $stderr.puts "Warning: Claude exited with status #{claude_status.exitstatus}"
    $stderr.puts claude_output unless claude_output.strip.empty?
    $stderr.puts "Falling back to 'wip' message"
    message = "wip"
  elsif claude_output.strip.empty?
    $stderr.puts "Warning: Claude returned empty output, falling back to 'wip'"
    message = "wip"
  else
    lines = claude_output.strip.lines.map(&:rstrip)
    subject = lines.first[0, 50]
    body = lines.drop(1).drop_while(&:empty?)
    formatted_body = body.map { |l| wrap(l, 72) }.join("\n")
    message = formatted_body.empty? ? subject : "#{subject}\n\n#{formatted_body}"
  end
end

if no_edit
  # --no-edit means we skip -m (used with --amend)
else
  # Write message to a temp file to avoid shell escaping issues
  require 'tempfile'
  msgfile = Tempfile.new('git-commit-msg')
  msgfile.write(message)
  msgfile.close
  commit_command.concat(" -F #{msgfile.path}")
end

puts shell(commit_command)

return unless push

push_command = "git push -u origin #{branch}"
push_command.concat(" --force-with-lease") if force

puts shell(push_command)