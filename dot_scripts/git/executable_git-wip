#!/usr/bin/env ruby
# frozen_string_literal: true

# git-wip - Quick commit all changes with a default "wip" message.
#
# Usage: git wip [options]
#
# Options:
#   -m, --message M     Commit message (default: "wip")
#   -p, --push          Push after commit
#   -f, --force         Force push with --force-with-lease (requires -p)
#   --ai                Auto-generate commit message with Claude
#   --amend             Amend the last commit
#   --no-edit           Don't edit the commit message (useful with --amend)
#   --no-verify         Bypass pre-commit and commit-msg hooks
#
# Refuses to push to master/main unless --force is given.
require 'optparse'
require_relative 'utils'

branch = Utils.shell("git rev-parse --abbrev-ref HEAD").strip

push = false
force = false
message = "wip"
no_edit = false
ai_message = false
commit_command = +"git commit"

OptionParser.new do |opts|
  opts.banner = "Usage: git wip [options]\n\nQuick commit all changes with a default \"wip\" message.\nRefuses to push to master/main unless --force is given.\n\n"

  opts.on("-p", "--push", "Push after commit") do |_v|
    push = true
  end

  opts.on("-f", "--force", "Force push") do |_v|
    force = true
  end

  opts.on("-m M", "--message M", String, "Commit message") do |v|
    message = v
  end

  opts.on("--no-verify", "Bypass pre-commit and commig-msg hooks") do |_v|
    commit_command.concat(" --no-verify")
  end

  opts.on("--no-edit", "do not edit the commit message before comitting") do |_v|
    no_edit = true
    commit_command.concat(" --no-edit")
  end

  opts.on("--amend", "amend the tip of the current branch") do |_v|
    commit_command.concat(" --amend")
  end

  opts.on("--ai", "Use Claude to auto-generate commit message from staged changes") do |_v|
    ai_message = true
  end
end.parse!

if %w[master main].include?(branch) && push && !force
  puts "Cannot use push flag on #{branch}. Please run with the --force flag if you are 100% sure of what you are doing."
  exit(-1)
end

puts Utils.shell("git add --all")

if ai_message
  diff_full = `git diff --cached`

  prompt = <<~PROMPT
    Summarize this diff as: one subject line, then a blank line, then the commit description. Use bullet points for different subjects.

    Do not wrap the output in a code block.

    #{diff_full}
  PROMPT

  success, ai_output = Utils.ai_generate(prompt, model: "sonnet")

  if success
    lines = ai_output.lines.map(&:rstrip)
    subject = Utils.wrap(lines.first, 72)
    body = lines.drop(1).drop_while(&:empty?)
    formatted_body = body.map { |l| Utils.wrap(l, 72) }.join("\n")
    message = formatted_body.empty? ? subject : "#{subject}\n\n#{formatted_body}"
  else
    warn "Warning: Claude failed, falling back to 'wip' message"
    message = "wip"
  end
end

if no_edit
  # --no-edit means we skip -m (used with --amend)
else
  # Write message to a temp file to avoid shell escaping issues
  require 'tempfile'
  msgfile = Tempfile.new('git-commit-msg')
  msgfile.write(message)
  msgfile.close
  commit_command.concat(" -F #{msgfile.path}")
end

puts Utils.shell(commit_command)

return unless push

push_command = "git push -u origin #{branch}"
push_command.concat(" --force-with-lease") if force

puts Utils.shell(push_command)
