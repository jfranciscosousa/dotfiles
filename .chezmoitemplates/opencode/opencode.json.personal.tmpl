{{/* Personal machines use OpenCode Go by default. Remote work machines use the remote template instead. */}}
{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.7-code",
  "agent": {
    "research-fast": {
      "mode": "primary",
      "description": "Read-only explorer: fuzzy-finds files, reads code, and checks assumptions. Implements nothing.",
      "model": "opencode-go/deepseek-v4-flash",
      "prompt": "{file:./prompts/research-fast.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    }
  },
  "instructions": ["{{ .chezmoi.homeDir }}/.brains/RTK.md"],
  "plugin": [
    ".\/plugins\/rtk.ts",
    ".\/plugins\/zed-bell.js",
    "opencode-websearch"
  ]
}
