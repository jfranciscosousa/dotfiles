{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "disabled_hooks": ["session-notification"],
{{- if hasPrefix "Remote-" .chezmoi.hostname }}
  "agents": {
    "sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "prometheus": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "atlas": {
      "model": "anthropic/claude-sonnet-4-6"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "metis": {
      "model": "anthropic/claude-sonnet-4-6",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "multimodal-looker": {
      "model": "anthropic/claude-haiku-4-5"
    },
    "sisyphus-junior": {
      "model": "anthropic/claude-sonnet-4-6"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "xhigh",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "deep": {
      "model": "openai/gpt-5.5",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "anthropic/claude-opus-4-7",
          "variant": "max"
        }
      ]
    },
    "artistry": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini"
    },
    "unspecified-high": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "max"
    },
    "writing": {
      "model": "anthropic/claude-opus-4-7",
      "variant": "high"
    }
  }
{{- else }}
  "agents": {
    "sisyphus": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "oracle": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "explore": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "multimodal-looker": {
      "model": "opencode/mimo-v2-omni-free"
    },
    "prometheus": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "metis": {
      "model": "opencode/qwen3.6-plus-free",
      "fallback_models": [
        {
          "model": "opencode/deepseek-v4-flash-free"
        }
      ]
    },
    "momus": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "atlas": {
      "model": "opencode/qwen3.6-plus-free"
    },
    "sisyphus-junior": {
      "model": "opencode/deepseek-v4-flash-free"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "ultrabrain": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "deep": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "artistry": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "quick": {
      "model": "opencode/deepseek-v4-flash-free"
    },
    "unspecified-low": {
      "model": "opencode/qwen3.6-plus-free"
    },
    "unspecified-high": {
      "model": "opencode/qwen3.6-plus-free"
    },
    "writing": {
      "model": "opencode/qwen3.6-plus-free"
    }
  }
{{- end }}
}
