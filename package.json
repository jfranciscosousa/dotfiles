{
  "name": "dotfiles",
  "private": true,
  "type": "module",
  "scripts": {
    "fmt": "zx scripts/format-dotfiles.ts",
    "format": "pnpm run fmt",
    "format:check": "oxfmt --check --disable-nested-config .",
    "lint": "pnpm typecheck && zx scripts/lint-dotfiles.ts",
    "lint:staged": "pnpm typecheck && lint-staged",
    "prepare": "husky",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.80.3",
    "@earendil-works/pi-tui": "^0.80.3",
    "@taplo/cli": "0.7.0",
    "@types/fs-extra": "11.0.4",
    "@types/node": "26.1.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "shellcheck": "4.1.0",
    "typebox": "^1.3.6",
    "typescript": "6.0.3",
    "zx": "8.8.5"
  },
  "lint-staged": {
    "*": "zx scripts/lint-staged-dotfiles.ts",
    ".*": "zx scripts/lint-staged-dotfiles.ts"
  },
  "packageManager": "pnpm@11.8.0"
}
