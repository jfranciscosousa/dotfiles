{{- /* chezmoi:modify-template */ -}}
{{- $provider := "openai" -}}
{{- if not (hasPrefix "Remote-" .chezmoi.hostname) -}}
{{- $provider = "openai-codex" -}}
{{- end -}}

{{- $existing := dict -}}
{{- if .chezmoi.stdin -}}
{{- $existing = .chezmoi.stdin | fromJson -}}
{{- end -}}

{{- $defaultModel := index $existing "defaultModel" | default "gpt-5.6-terra" -}}
{{- $managed := dict
  "theme" "dark"
  "defaultProvider" $provider
  "defaultModel" $defaultModel
  "hideThinkingBlock" true
  "enabledModels" (list
    (printf "%s/gpt-5.6-luna" $provider)
    (printf "%s/gpt-5.6-sol" $provider)
    (printf "%s/gpt-5.6-terra" $provider)
  )
  "shellPath" "/bin/zsh"
-}}

{{ mergeOverwrite $existing $managed | toPrettyJson }}
