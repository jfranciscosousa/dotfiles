{{/* Remote work machines intentionally use GPT/OpenAI, not OpenCode Go. */}}
{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openai"],
  "model": "openai/gpt-5.6-terra",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-sol": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.6-terra": {
          "options": {
            "reasoningEffort": "high",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        },
        "gpt-5.6-luna": {
          "options": {
            "reasoningEffort": "low",
            "textVerbosity": "low",
            "reasoningSummary": "auto"
          }
        }
      }
    }
  },
  "agent": {
    "plan": {
      "model": "openai/gpt-5.6-sol",
      "options": {
        "reasoningEffort": "low"
      }
    },
    "build": {
      "model": "openai/gpt-5.6-terra",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "general": {
      "model": "openai/gpt-5.6-terra",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "explore": {
      "model": "openai/gpt-5.6-luna",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "compaction": {
      "model": "openai/gpt-5.6-terra",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "summary": {
      "model": "openai/gpt-5.6-terra",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "title": {
      "model": "openai/gpt-5.6-luna",
      "options": {
        "reasoningEffort": "high"
      }
    },
    "build-deep": {
      "mode": "primary",
      "description": "Like build, but uses GPT-5.6 Sol",
      "model": "openai/gpt-5.6-sol"
    },
    "build-fast": {
      "mode": "primary",
      "description": "Guided, low-exploration flow on GPT-5.6 Luna low reasoning",
      "model": "openai/gpt-5.6-luna",
      "prompt": "{file:./prompts/build-fast.md}",
      "options": {
        "reasoningEffort": "low",
        "textVerbosity": "low"
      }
    },
    "research-fast": {
      "mode": "primary",
      "description": "Read-only explorer: fuzzy-finds files, reads code, and checks assumptions. Implements nothing.",
      "model": "openai/gpt-5.6-luna",
      "prompt": "{file:./prompts/research-fast.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "mcp-god": {
      "mode": "all",
      "description": "MCP-only gateway that calls the services requested by parent agents and reports the results back.",
      "model": "openai/gpt-5.6-luna",
      "options": {
        "reasoningEffort": "high"
      },
      "prompt": "You are an MCP-only gateway for parent agents. Call only the requested Linear, Snowflake, Sentry, Honeycomb, Notion, or Slack MCP tools, then report the results back to the parent thorougly. Do not perform unrelated work or extend the task beyond the parent's request.",
      "permission": {
        "linear_*": "allow",
        "snowflake_*": "allow",
        "sentry_*": "allow",
        "honeycomb_*": "allow",
        "notion_*": "allow",
        "slack_*": "allow"
      }
    }
  },
  "mcp": {
    "linear": {
      "type": "remote",
      "url": "https://mcp.linear.app/mcp",
      "enabled": true
    },
    "snowflake": {
      "type": "remote",
      "url": "https://mcp-gateway.eu-west-1.data.remote.com/snowflake/mcp",
      "enabled": true
    },
    "sentry": {
      "type": "remote",
      "url": "https://mcp.sentry.dev/mcp",
      "enabled": true
    },
    "honeycomb": {
      "type": "remote",
      "url": "https://mcp.eu1.honeycomb.io/mcp",
      "enabled": true
    },
    "notion": {
      "type": "remote",
      "url": "https://mcp.notion.com/mcp",
      "enabled": true
    },
    "slack": {
      "type": "remote",
      "url": "https://mcp.slack.com/mcp",
      "oauth": {
        "clientId": "1601185624273.8899143856786",
        "callbackPort": 3118,
        "redirectUri": "http://localhost:3118/callback"
      },
      "enabled": true
    }
  },
  "permission": {
    "linear_*": "deny",
    "snowflake_*": "deny",
    "sentry_*": "deny",
    "honeycomb_*": "deny",
    "notion_*": "deny",
    "slack_*": "deny"
  },
  "instructions": ["{{ .chezmoi.homeDir }}/.brains/RTK.md"],
  "plugin": [
    ".\/plugins\/rtk.ts",
    ".\/plugins\/zed-bell.js",
    "opencode-websearch"
  ]
}
