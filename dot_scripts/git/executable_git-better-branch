#!/usr/bin/env ruby
# frozen_string_literal: true

# git-better-branch - Better `git branch` listing.
#
# Lists local branches starting with the default branch (main/master),
# then the rest sorted by most recent commit. Each line shows the
# relative timestamp of the latest commit. Pass -r to also fetch the
# open PR (GitHub) or MR (GitLab) URL for each branch.
#
# Usage: git better-branch [-r]
require 'English'
require 'json'
require 'cgi'
require 'optparse'
require 'shellwords'
require_relative 'utils'

load_remotes = false

OptionParser.new do |opts|
  opts.banner = "Usage: git better-branch [-r]\n\n" \
                "List branches with latest commit time; -r also fetches PR/MR URLs.\n\n"
  opts.on("-r", "--remotes", "Fetch PR/MR URLs from GitHub/GitLab") do
    load_remotes = true
  end
end.parse!

# GitHub: query one PR per local branch, in parallel. Filtering by `--head`
# avoids missing PRs in repos with lots of activity.
def fetch_github_urls(branches)
  urls = {}
  return urls if branches.empty?
  return urls unless system("command -v gh > /dev/null 2>&1")

  mutex = Mutex.new
  branches.each_slice(16) do |chunk|
    threads = chunk.map do |branch|
      Thread.new do
        out = `gh pr list --head #{branch.shellescape} --state open --json url,author --limit 1 2>/dev/null`
        next unless $CHILD_STATUS.success?

        parsed = begin
          JSON.parse(out)
        rescue StandardError
          nil
        end
        next unless parsed.is_a?(Array) && !parsed.empty?

        pr = parsed.first
        author = pr.dig("author", "login")
        mutex.synchronize { urls[branch] = { url: pr["url"], author: author } }
      rescue StandardError
        # Per-branch failure shouldn't abort the whole listing.
      end
    end
    threads.each(&:join)
  end

  urls
end

# GitLab: query one MR per local branch, in parallel. Querying `source_branch`
# explicitly avoids the default filters and recency limits of a list call.
def fetch_gitlab_urls(branches)
  urls = {}
  return urls if branches.empty?
  return urls unless system("command -v glab > /dev/null 2>&1")

  mutex = Mutex.new
  branches.each_slice(16) do |chunk|
    threads = chunk.map do |branch|
      Thread.new do
        encoded = CGI.escape(branch)
        out = `glab api "projects/:fullpath/merge_requests?state=opened&source_branch=#{encoded}&per_page=1" 2>/dev/null`
        next unless $CHILD_STATUS.success?

        parsed = begin
          JSON.parse(out)
        rescue StandardError
          nil
        end
        next unless parsed.is_a?(Array) && !parsed.empty?

        mr = parsed.first
        author = mr.dig("author", "username")
        mutex.synchronize { urls[branch] = { url: mr["web_url"], author: author } }
      rescue StandardError
        # Per-branch failure shouldn't abort the whole listing.
      end
    end
    threads.each(&:join)
  end

  urls
end

def fetch_mr_urls(remote_url, branches)
  if remote_url.include?("github")
    fetch_github_urls(branches)
  elsif remote_url.include?("gitlab")
    fetch_gitlab_urls(branches)
  else
    {}
  end
end

def fetch_me(remote_url)
  if remote_url.include?("github")
    out = `gh api user --jq .login 2>/dev/null`
    $CHILD_STATUS.success? ? out.strip : nil
  elsif remote_url.include?("gitlab")
    out = `glab api user 2>/dev/null`
    return nil unless $CHILD_STATUS.success?

    begin
      JSON.parse(out)["username"]
    rescue StandardError
      nil
    end
  end
end

default_branch = Utils.detect_default_branch
current = `git rev-parse --abbrev-ref HEAD`.strip

format = '%(refname:short)|%(committerdate:relative)'
rows = `git for-each-ref --sort=-committerdate refs/heads/ --format='#{format}'`
       .each_line.map do |line|
  name, rel = line.strip.split("|", 2)
  { name: name, rel: rel || "" }
end

default_row = rows.find { |r| r[:name] == default_branch }
# Only treat the default-branch name as "the default" if it actually exists
# locally. Otherwise `detect_default_branch`'s "main" fallback would silently
# exclude a real local branch named `main` from PR lookups.
default_name = default_row ? default_branch : nil
others = rows.reject { |r| r[:name] == default_name }
ordered = [default_row, *others].compact

exit(0) if ordered.empty?

urls = {}
me = nil
if load_remotes
  remote_url = `git remote get-url origin 2>/dev/null`.strip
  if remote_url.empty?
    warn "git-better-branch: no 'origin' remote; skipping PR/MR fetch."
  else
    branches_to_fetch = ordered.map { |r| r[:name] }
    branches_to_fetch -= [default_name] if default_name
    urls_thread = Thread.new { fetch_mr_urls(remote_url, branches_to_fetch) }
    me_thread   = Thread.new { fetch_me(remote_url) }
    urls = urls_thread.value
    me   = me_thread.value
  end
end

GREEN = "\e[32m"
BLUE  = "\e[34m"
RESET = "\e[0m"

name_width = ordered.map { |r| r[:name].length }.max
rel_width  = ordered.map { |r| r[:rel].length }.max

ordered.each do |r|
  marker = r[:name] == current ? '*' : ' '
  line = "#{marker} #{r[:name].ljust(name_width)}  #{r[:rel].ljust(rel_width)}"
  if (info = urls[r[:name]])
    if (author = info[:author])
      is_me = me && author == me
      handle = is_me ? "@me" : "@#{author}"
      color = is_me ? GREEN : BLUE
      line += "  by: #{color}#{handle}#{RESET}"
    end
    line += "  #{info[:url]}"
  end
  puts line
end
