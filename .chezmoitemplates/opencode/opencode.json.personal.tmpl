{{/* Personal machines use OpenCode with GPT models. */}}
{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": ["openai"],
  "model": "openai/gpt-5.6-terra",
  "small_model": "openai/gpt-5.6-luna",
  "provider": {
    "openai": {
      "models": {
        "gpt-5.6-sol": { "options": { "reasoningEffort": "high", "textVerbosity": "low", "reasoningSummary": "auto" } },
        "gpt-5.6-terra": { "options": { "reasoningEffort": "high", "textVerbosity": "low", "reasoningSummary": "auto" } },
        "gpt-5.6-luna": { "options": { "reasoningEffort": "low", "textVerbosity": "low", "reasoningSummary": "auto" } }
      }
    }
  },
  "default_agent": "build",
  "agent": {
    "build": {
      "mode": "primary",
      "description": "Default primary agent for full development work.",
      "model": "openai/gpt-5.6-terra"
    },
    "build-deep": {
      "mode": "primary",
      "description": "Like build, but uses GPT-5.6 Sol for harder reasoning and deep refactoring.",
      "model": "openai/gpt-5.6-sol"
    },
    "build-fast": {
      "mode": "primary",
      "description": "Guided, low-exploration flow on GPT-5.6 Luna for quick edits and small tasks.",
      "model": "openai/gpt-5.6-luna",
      "prompt": "{file:./prompts/build-fast.md}"
    },
    "plan": {
      "mode": "primary",
      "description": "Restricted agent for planning and analysis without making changes.",
      "model": "openai/gpt-5.6-luna"
    },
    "research-fast": {
      "mode": "primary",
      "description": "Read-only explorer: fuzzy-finds files, reads code, and checks assumptions. Implements nothing.",
      "model": "openai/gpt-5.6-luna",
      "prompt": "{file:./prompts/research-fast.md}",
      "permission": {
        "edit": "deny",
        "bash": "ask"
      }
    },
    "general": {
      "mode": "subagent",
      "description": "General-purpose agent for researching complex questions and executing multi-step tasks.",
      "model": "openai/gpt-5.6-sol"
    },
    "explore": {
      "mode": "subagent",
      "description": "Fast, read-only agent for exploring codebases.",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "edit": "deny"
      }
    },
    "scout": {
      "mode": "subagent",
      "description": "Read-only agent for external docs and dependency research.",
      "model": "openai/gpt-5.6-luna",
      "permission": {
        "edit": "deny"
      }
    },
    "title": {
      "mode": "primary",
      "description": "Hidden system agent that generates short session titles.",
      "model": "openai/gpt-5.6-luna"
    },
    "summary": {
      "mode": "primary",
      "description": "Hidden system agent that creates session summaries.",
      "model": "openai/gpt-5.6-luna"
    },
    "compaction": {
      "mode": "primary",
      "description": "Hidden system agent that compacts long context into a smaller summary.",
      "model": "openai/gpt-5.6-luna"
    }
  },
  "instructions": ["{{ .chezmoi.homeDir }}/.brains/RTK.md"],
  "plugin": [
    ".\/plugins\/rtk.ts",
    ".\/plugins\/zed-bell.js",
    "opencode-websearch"
  ]
}
