#!/usr/bin/env ruby
# frozen_string_literal: true

# git-pr - Create a GitHub pull request with an AI-generated description.
#
# Usage: git pr [options]
#
# Options:
#   -t, --target BRANCH   Target branch (default: auto-detect main/master)
#   -h                    Show this help
#
# Looks for a PR template under .github/, fills it in with AI based on the
# branch diff, then creates the PR via gh.
require 'shellwords'
require_relative 'utils'

Utils.create_change_request(
  cmd: "pr",
  abbr: "PR",
  noun: "GitHub pull request",
  noun_short: "pull request",
  host_label: "GitHub",
  remote_host: "github",
  template_candidates: [
    ".github/pull_request_template.md",
    ".github/PULL_REQUEST_TEMPLATE.md",
    "pull_request_template.md",
    "PULL_REQUEST_TEMPLATE.md",
    "docs/pull_request_template.md"
  ],
  template_dirs: [
    ".github/PULL_REQUEST_TEMPLATE",
    ".github/pull_request_template"
  ],
  create: lambda { |title, description, target|
    "gh pr create --title #{title.shellescape} --body #{description.shellescape} --base #{target.shellescape}"
  }
)
