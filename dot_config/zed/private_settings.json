// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "agent_servers": {
    "opencode": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    }
  },
  "cli_default_open_behavior": "existing_window",
  "auto_install_extensions": {
    "catppuccin-icons": true,
    "elixir": true,
    "mdx": false
  },
  "icon_theme": "Catppuccin Mocha",
  "project_panel": {
    "dock": "left"
  },
  "agent": {
    "sidebar_side": "right",
    "dock": "right"
  },
  "git": {
    "worktree_directory": "/home/jfranciscosousa/.git-worktrees"
  },
  "collaboration_panel": {
    "button": false
  },
  "search": {
    "button": false
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "terminal": {
    "alternate_scroll": "on",
    "max_scroll_history_lines": 10000,
    "font_size": 14
  },
  "multi_cursor_modifier": "alt",
  "minimap": {
    "show": "never"
  },
  "buffer_font_family": "Fira Mono",
  "file_types": {
    "markdown": ["*.mdx"],
    "scss": ["*.css"],
    "javascript": ["*.jsx"],
    "html": ["*.liquid", "*.njk"]
  },
  "linked_edits": true,
  "tab_size": 2,
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Mirage"
  },
  // Elixir stuff
  "languages": {
    "Elixir": {
      "language_servers": ["dexter", "!expert", "!elixir-ls", "!next-ls", "!lexical"]
    },
    "EEx": {
      "language_servers": ["dexter", "!expert", "!elixir-ls", "!next-ls", "!lexical"]
    },
    "HEEx": {
      "language_servers": ["dexter", "!expert", "!elixir-ls", "!next-ls", "!lexical"]
    },
    "TypeScript": {
      "language_servers": ["tsgo", "oxlint", "!vtsls", "!typescript-language-server", "!eslint"]
    },
    "TSX": {
      "language_servers": ["tsgo", "oxlint", "!vtsls", "!typescript-language-server", "!eslint"]
    },
    "JavaScript": {
      "language_servers": ["tsgo", "oxlint", "!vtsls", "!typescript-language-server", "!eslint"]
    },
    "JSX": {
      "language_servers": ["tsgo", "oxlint", "!vtsls", "!typescript-language-server", "!eslint"]
    },
    "MDX": {
      "language_servers": ["!mdx-analyzer"]
    }
  },
  "lsp": {
    "dexter": {
      "binary": {
        "arguments": ["lsp"]
      },
      "initialization_options": {
        "followDelegates": true
      }
    },
    "solargraph": {
      "settings": {
        "use_bundler": false
      }
    }
  }
}
