# AppImage launchers (e.g. the T3-Code/opencode AppImage) export APPIMAGE /
# APPDIR / TARGET_APPIMAGE / REDIRECT_APPIMAGE / DESKTOPINTEGRATION, AND also
# ARGV0=<path-to-AppImage> into every subprocess. zsh uses ARGV0 as argv[0] for
# every exec'd child, so mise shims (which derive the shim name from argv[0])
# see "T3-Code-…AppImage" instead of e.g. "pnpm" and bail with
# "X is not a valid shim", breaking pnpm/node/etc. Drop those vars only when
# spawned by the T3-Code/opencode AppImage so normal terminals (and other
# AppImages) are unaffected. This must run before any mise shim is invoked,
# hence its placement at the top of .zshenv.
if [[ "$APPIMAGE" == */T3-Code-*.AppImage ]]; then
  unset ARGV0 APPIMAGE APPDIR TARGET_APPIMAGE REDIRECT_APPIMAGE DESKTOPINTEGRATION
fi

# Ensure that a non-login, non-interactive shell has a defined environment.
if [[ ( "$SHLVL" -eq 1 && ! -o LOGIN ) && -s "${ZDOTDIR:-$HOME}/.zprofile" ]]; then
  source "${ZDOTDIR:-$HOME}/.zprofile"
fi

# PATH exports here so they're available to all shells (interactive and non-interactive).
# This is needed for tools like Claude Code that spawn non-interactive shells.
#
# Add my custom scripts to path
export PATH="$PATH:$HOME/.scripts/git"
export PATH="$PATH:$HOME/.scripts/bin"
export PATH=/usr/local/bin:$PATH
export PATH="$PATH:$HOME/.local/bin"
# mise (runtime version manager) - shims keep runtimes on PATH for
# non-interactive shells (Claude Code, IDEs). Interactive shells additionally
# get `mise activate` in .zshrc.
export PATH="${MISE_DATA_DIR:-$HOME/.local/share/mise}/shims:$PATH"
# PNPM (the pnpm CLI + global bins live in $PNPM_HOME/bin)
export PNPM_HOME="$HOME/.local/share/pnpm"
export PATH="$PNPM_HOME/bin:$PATH"
# Opencode
export PATH=$HOME/.opencode/bin:$PATH

# Source private env file if it exists
[[ -f "${ZDOTDIR:-$HOME}/.private.sh" ]] && source "${ZDOTDIR:-$HOME}/.private.sh"
