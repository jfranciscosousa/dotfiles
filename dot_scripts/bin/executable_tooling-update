#!/bin/bash

set -e

# Update brew and all brew packages
brew update && brew upgrade

# Update asdf plugins
asdf plugin update --all

# Update all local home tools
TOOLVERSIONS="$HOME/.tool-versions"
[ -f "$TOOLVERSIONS" ] || exit 0

while read -r plugin version _; do
  [[ "$plugin" =~ ^#.*$ ]] && continue
  [[ -z "$plugin" ]] && continue

  latest=$(asdf latest "$plugin" 2>/dev/null) || continue
  asdf install "$plugin" "$latest" || true
  asdf set --home "$plugin" "$latest"
done < "$TOOLVERSIONS"